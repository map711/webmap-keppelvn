{
  "name": "wayfinder-map-keppelvn",
  "version": "0.0.0",
  "description": "Wayfinder map engine for Keppel VN (Saigon Centre)",
  "type": "module",
  "main": "dist/wayfinder-map.umd.js",
  "module": "dist/wayfinder-map.esm.js",
  "exports": {
    ".": {
      "import": "./dist/wayfinder-map.esm.js",
      "require": "./dist/wayfinder-map.umd.js"
    }
  },
  "scripts": {
    "build": "rollup -c && node scripts/build.js",
    "dev": "node .dev/server.mjs",
    "dev:ensure": "node .dev/ensure.mjs",
    "dev:stop": "node .dev/stop.mjs",
    "dev:status": "node .dev/status.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "deploy": "node scripts/deploy.js"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-terser": "^0.4.4",
    "dotenv": "^17.4.2",
    "eslint": "^9.19.0",
    "rollup": "^4.9.6",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "rbush": "^3.0.1"
  }
}
