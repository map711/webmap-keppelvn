# Copy to .env and fill in. Used by `npm run build` and `npm run deploy`.

# Build configuration
# Secret URL segment the demo gallery is deployed under (dist/<secret>/ ->
# s3://<bucket>/<secret>/). Letters, digits, underscore, dot, hyphen only.
BUILD_SECRET=your-secret-here

# DigitalOcean Spaces credentials (S3-compatible)
DO_SPACES_KEY=your_access_key
DO_SPACES_SECRET=your_secret_key
DO_SPACES_REGION=sgp1
DO_SPACES_BUCKET=your-bucket-name
